# --- RentYourTime environment ---
# Copy to `.env` (or set these in your process manager / systemd unit) and fill in.

# Public base URL of the deployment (used for Stripe redirect URLs).
APP_URL=https://your-domain.com

# Stripe — use sk_test_... and test Price IDs until you go live. Powers
# checkout, webhooks, billing history (docs/BILLING_PORTAL.md), and the
# Customer Portal (POST /api/billing/portal) — no separate secret needed.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Pro plan prices (create two recurring prices in Stripe):
#   monthly ($8.99 / month) and yearly ($89.99 / year).
STRIPE_PRICE_ID_MONTHLY=price_monthly_xxx
STRIPE_PRICE_ID_YEARLY=price_yearly_xxx

# Legacy single-price fallback used for the yearly plan when
# STRIPE_PRICE_ID_YEARLY is not set. Safe to remove once the two above are set.
STRIPE_PRICE_ID=price_xxx

# No separate price id or secret needed for one-time "Support the project"
# contributions (docs/CONTRIBUTIONS.md) — they reuse STRIPE_SECRET_KEY,
# STRIPE_WEBHOOK_SECRET, and APP_URL above, with a dynamically priced
# Checkout Session (price_data) instead of a fixed Stripe Price.

# Optional, development only (docs/CONTRIBUTIONS.md → "Development demo
# mode") — shows realistic accrued-rent + history on the Support the
# project screen for accounts with no real synced ledger yet. Ignored
# whenever NODE_ENV=production, no matter what these are set to, and
# whenever a real accrued_rent_cents exists for the account. Stripe
# Checkout is never mocked: contributing still creates a real Stripe Test
# Mode session using STRIPE_SECRET_KEY above.
ENABLE_SUPPORT_DEMO=true
SUPPORT_DEMO_ACCRUED_RENT_CENTS=2840
SUPPORT_DEMO_CURRENCY=usd

# Optional: email address notified (via AWS SES, see EMAIL_* below) on each
# new waitlist signup. Leave empty to disable owner emails — the Discord DM
# path (bot/.env's DISCORD_OWNER_ID, not this file) is independent either way.
# See docs/WAITLIST.md.
WAITLIST_NOTIFY_EMAIL=

# Optional: input to the one-time `npm run admin:grant` bootstrap script only
# (scripts/grant-admin.mjs) — never read by any request-handling code, so it
# can never silently grant ADMIN to whoever matches it. See docs/WAITLIST.md
# for both this and the raw-SQL alternative.
ADMIN_ACCOUNT_EMAIL=

# Optional: directory for the SQLite database (defaults to ./.data).
# DATA_DIR=/var/lib/rentyourtime

# DISCORD_OWNER_ID lives in bot/.env.example, not here — it's the bot
# process, not this app, that reads it (DM notifications for new signups).

# Apple App Store subscriptions — scaffolding only, see docs/APPLE_SUBSCRIPTIONS.md.
# Without these, POST /api/subscriptions/apple/sync returns 503. With them but
# without real JWS verification implemented, it returns 501. Either way it never
# grants Pro from unverified data. Do not put real values in source control.
APPLE_BUNDLE_ID=com.rentyourtime.app
APPLE_ISSUER_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Email verification (AWS SES v2) — see docs/EMAIL_VERIFICATION.md.
AWS_REGION=eu-central-1
# Optional: leave both empty on EC2/ECS with an IAM role attached — the AWS
# SDK's default credential provider chain picks it up automatically. Only
# set these for local development or hosts without an instance role.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
EMAIL_FROM=RentYourTime <no-reply-test@dev.rentyourtime.atlashc.pl>
# Optional.
EMAIL_REPLY_TO=
