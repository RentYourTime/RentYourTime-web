# --- RentYourTime environment ---
# Copy to `.env` (or set these in your process manager / systemd unit) and fill in.

# Public base URL of the deployment (used for Stripe redirect URLs).
APP_URL=https://your-domain.com

# Stripe — use sk_test_... and a test Price ID until you go live.
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PRICE_ID=price_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Optional: email address notified on each new waitlist signup.
# Leave empty to disable notifications.
WAITLIST_NOTIFY_EMAIL=

# Optional: directory for the SQLite database (defaults to ./.data).
# DATA_DIR=/var/lib/rentyourtime
