# --- RentYourTime Discord bot ---
# From the Discord Developer Portal (https://discord.com/developers/applications):

# Bot → Token (Reset Token to reveal)
DISCORD_TOKEN=your-bot-token

# General Information → Application ID
DISCORD_CLIENT_ID=your-application-id

# Your server's ID (enable Developer Mode → right-click server → Copy Server ID)
DISCORD_GUILD_ID=your-server-id

# Optional: your own Discord user ID. When set, the bot DMs you the email of
# every NEW signup. (Developer Mode → right-click your name → Copy User ID.)
# You must share a server with the bot and allow DMs from server members.
DISCORD_OWNER_ID=your-user-id

# Shared SQLite directory — MUST match the Next app's DATA_DIR so emails land
# in the same database. Defaults to ../.data (the app's default from this folder).
# On the server point both at the same absolute path, e.g. /var/lib/rentyourtime
DATA_DIR=../.data
